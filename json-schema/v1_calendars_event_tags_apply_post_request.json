{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://raw.githubusercontent.com/api-evangelist/luma/main/json-schema/v1_calendars_event_tags_apply_post_request.json",
  "title": "V1 Calendars Event Tags Apply Post Request",
  "type": "object",
  "properties": {
    "tag": {
      "type": "string",
      "description": "Tag ID (e.g., 'tag-123') or tag name"
    },
    "event_ids": {
      "minItems": 1,
      "type": "array",
      "items": {
        "type": "string"
      },
      "description": "Array of event IDs to apply the tag to"
    }
  },
  "required": [
    "tag",
    "event_ids"
  ]
}